{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Img2TypTeX",
  "version": "0.1.0",
  "identifier": "com.winkhaing.img2typtex",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
